
freq = { "%частота%" }
text = { "%текст%" }
who = { "%хто%" }
whom = { "%кому%" }
title = { "%заголовок%" }
location = { "%район%" }
date = { "%дата%" }
time = { "%час%" }
source = { "%джерело%" }
comment = { "%коментар%" }

literal = { (!"%" ~ ANY)* }
invalid = { "%" ~ literal ~ "%" }

special = _{
    freq |
    text |
    who |
    whom |
    title |
    location |
    date |
    time |
    source |
    comment |
    invalid
}

format = _{ special? ~ literal ~ (special ~ literal)* ~ special? }
